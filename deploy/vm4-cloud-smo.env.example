# VM4: Cloud site — SMO domain
# O-RAN role: Service Management and Orchestration (logging, reporting, handover)
# Copy to vm4-cloud-smo.env and replace IPs with actual testbed addresses.

VM_IP=10.0.0.4
VM1_IP=10.0.0.1
VM2_IP=10.0.0.2
VM3_IP=10.0.0.3
VM4_IP=10.0.0.4

# Broker config
BROKER_DOMAIN=d4
BROKER_PORT=8080
PEER_URL_1=http://10.0.0.1:8080
PEER_URL_2=http://10.0.0.2:8080
PEER_URL_3=http://10.0.0.3:8080
FEDERATION_INTERVAL_S=10
WAN_COST_MS=0

# Workers
WORKER_SLICE=best-effort
WORKER_BID_COST_MS=60
