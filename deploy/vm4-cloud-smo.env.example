# VM4: Cloud site — SMO domain
# O-RAN role: Service Management and Orchestration (logging, reporting, handover)
# Copy to vm4-cloud-smo.env and replace IPs with actual testbed addresses.

VM_IP=<vm-4-ip>
VM1_IP=<vm-1-ip>
VM2_IP=<vm-2-ip>
VM3_IP=<vm-3-ip>
VM4_IP=<vm-4-ip>

# Broker config
BROKER_DOMAIN=d4
BROKER_PORT=8080
PEER_URL_1=http://<vm-1-ip>:8080
PEER_URL_2=http://<vm-2-ip>:8080
PEER_URL_3=http://<vm-3-ip>:8080
FEDERATION_INTERVAL_S=10
WAN_COST_MS=0

# Broker module (src.broker.neural_broker or src.broker.static_broker)
BROKER_MODULE=src.broker.neural_broker
PLACEMENT_MODE=neural
PLACEMENT=round_robin

# Workers
WORKER_SLICE=best-effort
WORKER_BID_COST_MS=60
