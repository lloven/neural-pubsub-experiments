# VM1: Edge site — DU domain
# O-RAN role: Distributed Unit (fronthaul processing, raw measurements)
# Copy to vm1-edge-du.env and replace IPs with actual testbed addresses.

VM_IP=<vm-1-ip>
VM1_IP=<vm-1-ip>
VM2_IP=<vm-2-ip>
VM3_IP=<vm-3-ip>
VM4_IP=<vm-4-ip>

# Broker config
BROKER_DOMAIN=d1
BROKER_PORT=8080
PEER_URL_1=http://<vm-2-ip>:8080
PEER_URL_2=http://<vm-3-ip>:8080
PEER_URL_3=http://<vm-4-ip>:8080
FEDERATION_INTERVAL_S=10
WAN_COST_MS=0

# Broker module (src.broker.neural_broker or src.broker.static_broker)
BROKER_MODULE=src.broker.neural_broker
PLACEMENT_MODE=neural
PLACEMENT=round_robin

# Workers
WORKER_SLICE=URLLC
WORKER_BID_COST_MS=100
