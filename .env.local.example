# =============================================================================
# .env.local — Remote execution configuration for run-experiments.sh
#
# Copy to .env.local and edit for your environment.
# This file is gitignored; .env.local.example is committed as a template.
# =============================================================================

# --- Single-site phases (A, B, D) -------------------------------------------
# SSH alias (from ~/.ssh/config) for the primary experiment host.
HOST_D1=<your-ssh-alias-for-domain-1>
# Absolute path to the neural-pubsub repo on the remote host.
HOST_D1_DIR=neural-pubsub
# Git remote name used to push code to the D1 host.
HOST_D1_GIT=<your-git-remote-name-for-domain-1>

# --- Cross-site phases (C) — second domain ----------------------------------
# Uncomment and configure when running Phase C (cross-site federation).
# HOST_D2=<your-ssh-alias-for-domain-2>
# HOST_D2_DIR=~/neural-pubsub
# HOST_D2_GIT=<your-git-remote-name-for-domain-2>
